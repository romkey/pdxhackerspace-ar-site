# Copy this file to `.env` (same directory as docker-compose.yml) and edit
# the values. `docker compose up` will pass everything in `.env` to the
# container as environment variables.
#
# `.env` is gitignored so secrets like HA_TOKEN don't leak.

# ---------------------------------------------------------------------------
# Events dashboard (events.html)
# ---------------------------------------------------------------------------

# iCalendar feed URL fetched by the AR events dashboard. Nginx proxies
# this on /feed/calendar.ics with CORS headers added.
CALENDAR_ICS_URL=https://events.pdxhackerspace.org/calendar.ics

# How many upcoming events to show on the AR dashboard.
CALENDAR_EVENT_COUNT=3

# ---------------------------------------------------------------------------
# Printer status AR (printer.html)
# ---------------------------------------------------------------------------

# Home Assistant base URL + long-lived access token. The token never
# leaves the container — it's only used by the in-container backend
# at /api/printer/<id> to fetch HA states for the browser.
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=

# How often the browser polls the backend (seconds).
PRINTER_REFRESH_SECONDS=10

# Printer 0. Add PRINTER_1_NAME / PRINTER_1_SENSOR_PREFIX (etc.) below
# to configure additional printers; the page selects between them via
# ?printer=<id> today and via different markers in the future.
PRINTER_0_NAME=Prusa
# Base entity prefix in HA. The backend appends `_progress`,
# `_filename`, `_nozzle_temperature`, etc. to find each sensor.
PRINTER_0_SENSOR_PREFIX=sensor.prusa
# Optional: HA camera/image entity holding the current job's preview
# thumbnail. The backend proxies it at /api/printer/<id>/preview so the
# token never reaches the browser. If unset, it's auto-derived from the
# sensor prefix (sensor.prusa -> camera.prusa). Set to empty to disable.
#PRINTER_0_PREVIEW_ENTITY=camera.prusa

# Example second printer (uncomment + edit):
#PRINTER_1_NAME=Prusa XL
#PRINTER_1_SENSOR_PREFIX=sensor.prusa_xl
#PRINTER_1_PREVIEW_ENTITY=camera.prusa_xl
